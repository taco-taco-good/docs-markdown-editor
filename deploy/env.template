# Copy this file to `.env` at the repository root and adjust values for your environment.

# Path the app reads inside Docker.
WORKSPACE_ROOT=/data

# Host path bind-mounted to WORKSPACE_ROOT.
WORKSPACE_ROOT_HOST=/srv/foldmark-data

# Server bind address and port.
HOST=0.0.0.0
PORT=3001

# Public hostname for reverse proxy / OIDC callback configuration.
PUBLIC_HOST=localhost
